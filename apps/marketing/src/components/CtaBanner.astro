---
const signupUrl = 'https://app.trenchcoat.io/signup';
---

<section class="bg-brand-surface-2 py-20">
  <div class="mx-auto max-w-3xl px-6 text-center">
    <p class="mb-4 text-xs font-medium uppercase tracking-widest text-brand-accent">Get started</p>
    <h2 class="text-3xl font-semibold text-brand-fg" style="letter-spacing: -0.02em">
      Get visibility into your AI agents in minutes
    </h2>
    <p class="mt-4 text-lg text-brand-fg-muted">
      Connect the Trenchcoat plugin, events start flowing immediately
    </p>
    <a
      href={signupUrl}
      class="mt-8 inline-block rounded-lg bg-brand-accent px-8 py-4 text-base font-medium text-brand-bg transition-colors hover:bg-brand-accent-bright focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-accent"
    >
      Start for free
    </a>
  </div>
</section>
