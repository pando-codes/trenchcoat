---
interface Props {
  feature: string;
  free: string | boolean;
  pro: string | boolean;
  enterprise: string | boolean;
}

const { feature, free, pro, enterprise } = Astro.props;

function cell(value: string | boolean): string {
  if (value === true) return '✓';
  if (value === false) return '—';
  return value;
}
---
<tr class="border-t border-brand-border">
  <th scope="row" class="py-4 pr-6 text-left text-sm text-brand-fg-muted">{feature}</th>
  <td class="px-6 py-4 text-center text-sm text-brand-fg-subtle">{cell(free)}</td>
  <td class="px-6 py-4 text-center text-sm font-medium text-brand-accent">{cell(pro)}</td>
  <td class="pl-6 py-4 text-center text-sm text-brand-fg-subtle">{cell(enterprise)}</td>
</tr>
