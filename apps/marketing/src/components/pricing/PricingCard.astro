---
interface Props {
  name: string;
  price: string;
  description: string;
  features: string[];
  ctaLabel: string;
  ctaHref: string;
  highlighted?: boolean;
}

const {
  name,
  price,
  description,
  features,
  ctaLabel,
  ctaHref,
  highlighted = false,
} = Astro.props;
---
<div
  class:list={[
    'flex flex-col rounded-xl border p-8',
    highlighted
      ? 'border-brand-accent bg-brand-accent-tint ring-1 ring-brand-accent'
      : 'border-brand-border bg-brand-surface',
  ]}
>
  {highlighted && (
    <div class="mb-4 self-start rounded-full bg-brand-accent px-3 py-1 text-xs font-medium text-brand-bg">
      Most popular
    </div>
  )}
  <h3 class="text-lg font-semibold text-brand-fg">{name}</h3>
  <div class="mt-4 text-4xl font-bold text-brand-fg" style="letter-spacing: -0.03em">{price}</div>
  <p class="mt-2 text-sm text-brand-fg-muted">{description}</p>
  <ul class="mt-8 flex flex-1 flex-col gap-3">
    {features.map(feature => (
      <li class="flex items-start gap-3 text-sm text-brand-fg-muted">
        <svg
          class="mt-0.5 h-4 w-4 shrink-0 text-brand-accent"
          viewBox="0 0 16 16"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.75.75 0 0 1 1.06-1.06L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z" />
        </svg>
        {feature}
      </li>
    ))}
  </ul>
  <a
    href={ctaHref}
    class:list={[
      'mt-8 block w-full rounded-lg px-6 py-3 text-center text-sm font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-accent',
      highlighted
        ? 'bg-brand-accent text-brand-bg hover:bg-brand-accent-bright'
        : 'border border-brand-border-strong text-brand-fg-muted hover:border-brand-fg-faint hover:text-brand-fg',
    ]}
  >
    {ctaLabel}
  </a>
</div>
