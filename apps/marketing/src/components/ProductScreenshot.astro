---
import { Image } from 'astro:assets';
import dashboardImg from '../assets/dashboard.png';
---
<section class="bg-brand-surface py-16">
  <div class="mx-auto max-w-5xl px-6">
    <div class="overflow-hidden rounded-xl border border-brand-border shadow-2xl">
      <!-- Browser chrome -->
      <div class="flex items-center gap-2 border-b border-brand-border bg-brand-surface-2 px-4 py-3">
        <div class="flex gap-1.5">
          <div class="h-3 w-3 rounded-full bg-brand-danger opacity-70"></div>
          <div class="h-3 w-3 rounded-full bg-brand-accent opacity-70"></div>
          <div class="h-3 w-3 rounded-full bg-brand-success opacity-70"></div>
        </div>
        <div class="mx-auto rounded-md border border-brand-border bg-brand-surface-3 px-3 py-1 text-xs text-brand-fg-subtle">
          app.trenchcoat.io
        </div>
      </div>
      <Image
        src={dashboardImg}
        alt="Trenchcoat Overview dashboard showing session, event, and tool-use metrics with a daily activity chart and top tools breakdown"
        class="w-full"
        loading="eager"
      />
    </div>
  </div>
</section>
